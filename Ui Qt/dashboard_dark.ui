 <class>DashboardWidget</class>
 <widget class="QWidget" name="DashboardWidget">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>1000</width><height>800</height></rect>
  </property>

  <!-- ══ Dark Mode Stylesheet ══ -->
  <property name="styleSheet">
   <string notr="true">
    /* ─── KPI Cards ─── */
    QFrame#card_total {
        background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
            stop:0 #1E3A5F, stop:1 #1C2944);
        border-radius: 12px;
        border: 1px solid #2D4A7A;
    }
    QFrame#card_expiring {
        background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
            stop:0 #78350F, stop:1 #451A03);
        border-radius: 12px;
        border: 1px solid #92400E;
    }
    QFrame#card_expired {
        background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
            stop:0 #450A0A, stop:1 #2D0707);
        border-radius: 12px;
        border: 1px solid #7F1D1D;
    }
    QFrame#card_low_stock {
        background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
            stop:0 #064E3B, stop:1 #022C22);
        border-radius: 12px;
        border: 1px solid #065F46;
    }

    /* ─── Chart and Alert Frames ─── */
    QFrame#chart_card, QFrame#alert_card {
        background-color: #273947;
        border: 1px solid #3E4C59;
        border-radius: 8px;
    }

    /* ─── Tables: mục quan trọng — tránh background trắng khi chọn ─── */
    QTableWidget {
        background-color: #273947;
        border: 1px solid #3E4C59;
        border-radius: 8px;
        gridline-color: #3E4C59;
        color: #E4E7EB;
        alternate-background-color: #2D3F4F;
        outline: none;
    }
    QTableWidget::item {
        background-color: transparent;
        color: #E4E7EB;
        border: none;
    }
    QTableWidget::item:alternate {
        background-color: #2D3F4F;
        color: #E4E7EB;
    }
    QTableWidget::item:selected {
        background-color: #1D4ED8;
        color: #FFFFFF;
    }
    QTableWidget::item:selected:alternate {
        background-color: #1D4ED8;
        color: #FFFFFF;
    }
    QTableWidget::item:hover:!selected {
        background-color: #1E3A5F;
        color: #E4E7EB;
    }
    QTableWidget::item:focus {
        background-color: #1D4ED8;
        color: #FFFFFF;
        border: none;
    }
    QHeaderView::section {
        background-color: #273947;
        color: #9AA5B1;
        font-weight: bold;
        border: none;
        border-bottom: 1px solid #3E4C59;
        padding: 8px;
    }
    QHeaderView {
        background-color: #273947;
    }

    /* ─── Scroll Area ─── */
    QScrollArea {
        background-color: transparent;
        border: none;
    }
    QScrollArea > QWidget > QWidget {
        background-color: transparent;
    }
    QScrollBar:vertical {
        background-color: transparent;
        width: 8px;
        border-radius: 4px;
        margin: 2px;
    }
    QScrollBar::handle:vertical {
        background-color: #3E4C59;
        border-radius: 4px;
        min-height: 24px;
    }
    QScrollBar::handle:vertical:hover {
        background-color: #9AA5B1;
    }
    QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
        height: 0px;
    }
   </string>
  </property>

