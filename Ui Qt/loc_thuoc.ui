        background-color: #F8FAFC;
        border: 1px solid #E2E8F0;
        border-radius: 8px;
        padding-left: 10px;
        color: #1E293B;
        font-size: 13px;
    }

    QComboBox:focus {
        border: 1px solid #2563EB;
    }
   </string>
